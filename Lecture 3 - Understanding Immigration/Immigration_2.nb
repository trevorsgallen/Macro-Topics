    RowBox[{"Graphics", "[", 
     RowBox[{"Text", "[", 
      RowBox[{"\"\<Don't Immigrate\>\"", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "2.4"}], ",", "2.4"}], "}"}]}], "]"}], "]"}], ",", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"z", "-", "x"}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", 
        RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", 
