Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pop1U", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"Take", "[", 
     RowBox[{"pop1", ",", "All", ",", "1"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pop1M", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"Take", "[", 
     RowBox[{"pop1", ",", "All", ",", 
      RowBox[{"{", 
       RowBox[{"2", ",", "2"}], "}"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bestU", "=", 
   RowBox[{"MapThread", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Boole", "[", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"#1", "-", "x"}], ">", "#2"}], ")"}], "]"}], "*", "#1"}], 
        ")"}], "+", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Boole", "[", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"#1", "-", "x"}], "<=", "#2"}], ")"}], "]"}], "*", "#1"}],
         ")"}]}], "&"}], ",", 
     RowBox[{"{", 
      RowBox[{"pop1U", ",", "pop1M"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Mbest", "=", 
   RowBox[{"MapThread", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Boole", "[", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"#1", "-", "x"}], "<=", "#2"}], ")"}], "]"}], "&"}], ",", 
     RowBox[{"{", 
      RowBox[{"pop1U", ",", "pop1M"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ubest", "=", 
   RowBox[{"1", "-", "Mbest"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Mbestind", "=", 
   RowBox[{"Position", "[", 
    RowBox[{"Mbest", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ubestind", "=", 
   RowBox[{"Position", "[", 
    RowBox[{"Ubest", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xM", "=", 
   RowBox[{"Extract", "[", 
    RowBox[{"pop1U", ",", "Mbestind"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"yM", "=", 
   RowBox[{"Extract", "[", 
    RowBox[{"pop1M", ",", "Mbestind"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xU", "=", 
   RowBox[{"Extract", "[", 
    RowBox[{"pop1U", ",", "Ubestind"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"yU", "=", 
   RowBox[{"Extract", "[", 
    RowBox[{"pop1M", ",", "Ubestind"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"temp", "=", 
  RowBox[{"Show", "[", 
   RowBox[{
    RowBox[{"ListPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Partition", "[", 
         RowBox[{
          RowBox[{"Riffle", "[", 
           RowBox[{"xM", ",", "yM"}], "]"}], ",", "2"}], "]"}], ",", 
        RowBox[{"Partition", "[", 
         RowBox[{
          RowBox[{"Riffle", "[", 
           RowBox[{"xU", ",", "yU"}], "]"}], ",", "2"}], "]"}]}], "}"}], ",", 
      
      RowBox[{"PlotStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"Red", ",", "Blue"}], "}"}]}], ",", 
      RowBox[{"PlotLabel", "\[Rule]", "\"\<Utility in M and U\>\""}], ",", 
      RowBox[{"AxesLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
        "\"\<\!\(\*SubscriptBox[\(U\), \(U\)]\)\>\"", ",", 
         "\"\<\!\(\*SubscriptBox[\(U\), \(M\)]\)\>\""}], "}"}]}], ",", 
      RowBox[{"PlotRange", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "4"}], ",", "4"}], "}"}]}], "}"}]}]}], "]"}], ",", 
    RowBox[{"Graphics", "[", 
