   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{
  "\"\</Users/Tgallen/Dropbox/Yana/Immigration_NoCorr_NoCost.pdf\>\"", ",", 
   "temp"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"AvgUtGain1", "=", 
  RowBox[{"Mean", "[", 
   RowBox[{"MapThread", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Boole", "[", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"#1", "-", "x"}], ">", "#2"}], ")"}], "]"}], "*", 
       RowBox[{"(", 
        RowBox[{"#1", "-", "#2"}], ")"}]}], "&"}], ",", 
     RowBox[{"{", 
      RowBox[{"pop1U", ",", "pop1M"}], "}"}]}], "]"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"AvgUtGain2", "=", 
  RowBox[{"Mean", "[", 
   RowBox[{"MapThread", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Boole", "[", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"#1", "-", "x"}], ">", "#2"}], ")"}], "]"}], "*", 
       RowBox[{"(", 
