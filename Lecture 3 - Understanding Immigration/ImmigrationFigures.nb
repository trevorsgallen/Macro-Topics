   RowBox[{
    RowBox[{"(", 
     RowBox[{"A", "/.", "\[VeryThinSpace]", 
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"s", " ", "A", " ", 
          SuperscriptBox["k", 
           RowBox[{"\[Alpha]", "-", "1"}]]}], "\[Equal]", 
         RowBox[{
          RowBox[{"s", " ", "\[Delta]"}], "+", "n"}]}], "/.", 
        "\[VeryThinSpace]", 
        RowBox[{"{", 
