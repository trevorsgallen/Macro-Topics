Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pop1U", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"Take", "[", 
     RowBox[{"pop1alt", ",", "All", ",", "1"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pop1M", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"Take", "[", 
     RowBox[{"pop1alt", ",", "All", ",", 
      RowBox[{"{", 
       RowBox[{"2", ",", "2"}], "}"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bestU", "=", 
   RowBox[{"MapThread", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Boole", "[", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"#1", "-", "x"}], ">", "#2"}], ")"}], "]"}], "*", "#1"}], 
        ")"}], "+", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Boole", "[", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"#1", "-", "x"}], "<=", "#2"}], ")"}], "]"}], "*", "#1"}],
         ")"}]}], "&"}], ",", 
     RowBox[{"{", 
      RowBox[{"pop1U", ",", "pop1M"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Mbest", "=", 
   RowBox[{"MapThread", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Boole", "[", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"#1", "-", "x"}], "<=", "#2"}], ")"}], "]"}], "&"}], ",", 
     RowBox[{"{", 
      RowBox[{"pop1U", ",", "pop1M"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ubest", "=", 
   RowBox[{"1", "-", "Mbest"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Mbestind", "=", 
   RowBox[{"Position", "[", 
    RowBox[{"Mbest", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ubestind", "=", 
   RowBox[{"Position", "[", 
    RowBox[{"Ubest", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xM", "=", 
   RowBox[{"Extract", "[", 
    RowBox[{"pop1U", ",", "Mbestind"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"yM", "=", 
   RowBox[{"Extract", "[", 
    RowBox[{"pop1M", ",", "Mbestind"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xU", "=", 
   RowBox[{"Extract", "[", 
    RowBox[{"pop1U", ",", "Ubestind"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"yU", "=", 
   RowBox[{"Extract", "[", 
    RowBox[{"pop1M", ",", "Ubestind"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"temp", "=", 
  RowBox[{"Show", "[", 
   RowBox[{
    RowBox[{"ListPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Partition", "[", 
