Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"pop1U", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"Take", "[", 
       RowBox[{"pop5", ",", "All", ",", "1"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pop1M", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"Take", "[", 
       RowBox[{"pop5", ",", "All", ",", 
        RowBox[{"{", 
         RowBox[{"2", ",", "2"}], "}"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bestU", "=", 
     RowBox[{"MapThread", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Boole", "[", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"#1", "-", "x"}], ">", "#2"}], ")"}], "]"}], "*", 
           "#1"}], ")"}], "+", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Boole", "[", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"#1", "-", "x"}], "<=", "#2"}], ")"}], "]"}], "*", 
           "#1"}], ")"}]}], "&"}], ",", 
       RowBox[{"{", 
        RowBox[{"pop1U", ",", "pop1M"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Mbest", "=", 
     RowBox[{"MapThread", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Boole", "[", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"#1", "-", "x"}], "<=", "#2"}], ")"}], "]"}], "&"}], ",", 
       RowBox[{"{", 
        RowBox[{"pop1U", ",", "pop1M"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Ubest", "=", 
     RowBox[{"1", "-", "Mbest"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Mbestind", "=", 
     RowBox[{"Position", "[", 
      RowBox[{"Mbest", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
